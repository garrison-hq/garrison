{
  "name": "garrison-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --passWithNoTests --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "drizzle:pull": "bun run scripts/pull-supervisor-schema.ts",
    "drizzle:generate": "drizzle-kit generate && bun run drizzle/scripts/append-grants.ts",
    "drizzle:migrate": "drizzle-kit migrate",
    "lint:vault-discipline": "bun run scripts/lint-vault-discipline.ts",
    "test:integration": "next build && playwright test && bun run tests/integration/_server-coverage.ts"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@infisical/sdk": "5.0.2",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-virtual": "^3.13.24",
    "@uiw/react-codemirror": "^4.25.9",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.4",
    "next-intl": "^4.9.1",
    "postgres": "^3.4.9",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4.2.4",
    "@testcontainers/postgresql": "^11.14.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "22.18.13",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-istanbul": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "4.1.5",
    "c8": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "jsdom": "^29.1.1",
    "monocart-coverage-reports": "^2.12.11",
    "playwright": "1.59.1",
    "postcss": "8.5.6",
    "tailwindcss": "4.2.4",
    "testcontainers": "^11.14.0",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  }
}
