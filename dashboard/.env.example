# Dashboard runtime environment.
# Copy to .env and fill in the values for the M3 deployment.

# Postgres DSN for the dashboard's primary connection (better-auth
# storage + operational reads on M2-arc tables). Authenticates as
# the garrison_dashboard_app role created by T001.
DASHBOARD_APP_DSN=postgres://garrison_dashboard_app:CHANGEME@postgres:5432/garrison?sslmode=disable

# Postgres DSN for the vault sub-views ONLY. Authenticates as the
# garrison_dashboard_ro role created by T001. The dashboard's
# vault queries import from lib/db/vaultRoClient.ts and never
# from the appClient.
DASHBOARD_RO_DSN=postgres://garrison_dashboard_ro:CHANGEME@postgres:5432/garrison?sslmode=disable

# Random 32-byte hex string used by better-auth to sign session
# tokens. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=CHANGEME

# Public-facing base URL for the dashboard. Used by better-auth for
# invite-link generation and CSRF origin checks.
BETTER_AUTH_URL=http://localhost:3000

# M5.4 — Server-side fetch target for the knowledge-base pane's
# Server Actions (Company.md GET/PUT, recent palace writes, recent KG
# facts). The supervisor's dashboardapi server listens on port 8081
# inside the compose network.
DASHBOARD_SUPERVISOR_API_URL=http://garrison-supervisor:8081

# M5.4 — MinIO root credentials (env-on-container only; never logged).
# These are NOT used by the supervisor — they bootstrap the MinIO
# container itself. The supervisor reads scoped service-account
# credentials from Infisical at the paths configured by
# GARRISON_MINIO_ACCESS_KEY_PATH / GARRISON_MINIO_SECRET_KEY_PATH.
# See docs/ops-checklist.md M5.4 section for the `mc admin user
# svcacct add` invocation that mints the scoped account.
MINIO_ROOT_USER=garrison-admin
MINIO_ROOT_PASSWORD=CHANGEME-min-12-chars

# M5.4 — Infisical paths for the supervisor's scoped MinIO credentials.
# Operator populates these in Infisical post-deploy; supervisor reads
# them at startup via vault.Client.Fetch. The path MUST include the
# customer-id UUID prefix (M2.3 vault convention:
# /<customerId>/<role>/<env_var>); see docs/ops-checklist.md M5.4
# section. Replace <CUSTOMER_ID> with the value of `companies.id`.
GARRISON_MINIO_ACCESS_KEY_PATH=/<CUSTOMER_ID>/operator/MINIO_ACCESS_KEY
GARRISON_MINIO_SECRET_KEY_PATH=/<CUSTOMER_ID>/operator/MINIO_SECRET_KEY
