# Dockerfile.mockclaude.chat — produces garrison-mockclaude:m5
#
# Two-stage build:
#   stage 1: build the mockclaude Go binary statically
#   stage 2: minimal node:22-slim runtime (matches garrison-claude:m5
#            filesystem layout) with the binary symlinked at
#            /usr/local/bin/claude
#
# Build: make mockclaude-chat-image
# Tag:   garrison-mockclaude:m5
# Used:  CI / integration tests where a real CLAUDE_CODE_OAUTH_TOKEN
#        isn't available; the mock emits canned NDJSON responses that
#        match the spike §8.1 wire shape.

FROM golang:1.23-alpine AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
# mockclaude only imports stdlib (see internal/spawn/mockclaude/main.go);
# copy just that package rather than the whole supervisor tree so the
# image build does not pull in unrelated source / fixtures / vendor data.
COPY internal/spawn/mockclaude ./internal/spawn/mockclaude
RUN CGO_ENABLED=0 go build -o /out/mockclaude ./internal/spawn/mockclaude

FROM node:22-slim

COPY --from=build /out/mockclaude /usr/local/bin/claude
RUN chmod +x /usr/local/bin/claude

# Drop root: node:22-slim ships a non-root `node` user (uid 1000). The
# mock has no writable mounts and only emits canned NDJSON to stdout —
# running as the pre-existing `node` user matches Dockerfile.claude.
USER node
WORKDIR /home/node

ENTRYPOINT ["/usr/local/bin/claude"]
