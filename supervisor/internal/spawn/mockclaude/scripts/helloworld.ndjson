# Happy-path NDJSON fixture for T015 TestM21HelloWorldEndToEnd.
# Mirrors the event sequence the engineer agent would produce on a
# successful hello-world run against the M2.1 pipeline:
#   init  → assistant (tool_use write_file) → user (tool_result ok)
#   → result (success, total_cost_usd=0.003).
# The write-hello-txt directive makes the mock produce the file the
# supervisor's acceptance check looks for.
#write-hello-txt
{"type":"system","subtype":"init","session_id":"mock-session-helloworld","model":"claude-haiku-4-5-20251001","cwd":"/workspaces/engineering","tools":["Read","Write","Bash"],"mcp_servers":[{"name":"postgres","status":"connected"}]}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","content":[{"type":"text","text":"I'll read the ticket and write hello.txt with the ticket id."}]}}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","content":[{"type":"tool_use","name":"Write","input":{"path":"hello.txt","contents":"{{TICKET_ID}}"}}]}}
{"type":"user","message":{"content":[{"type":"tool_result","tool_use_id":"toolu_01","is_error":false,"content":[{"type":"text","text":"file written"}]}]}}
{"type":"result","subtype":"success","is_error":false,"duration_ms":842,"duration_api_ms":612,"total_cost_usd":0.003,"stop_reason":"end_turn","result":"hello.txt written","session_id":"mock-session-helloworld"}
