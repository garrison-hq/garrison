# Dockerfile.claude — produces garrison-claude:m5
#
# Two-stage build:
#   stage 1: install + verify @anthropic-ai/claude-code at the pinned
#            version
#   stage 2: minimal node:22-slim runtime with the npm-globaled package
#            symlinked at /usr/local/bin/claude
#
# Build: make chat-image
# Tag:   garrison-claude:m5
# Used:  M5.1 chat runtime (per-message ephemeral container spawned by
#        the supervisor via the docker-proxy)

FROM node:22-slim AS install

ARG CLAUDE_CODE_VERSION=2.1.170

# --ignore-scripts keeps arbitrary dependency postinstalls from
# executing during npm install (supply-chain posture). Since ~2.1.9x
# the package ships a thin npm wrapper whose postinstall downloads the
# platform-native claude binary — so that ONE known script is invoked
# explicitly afterwards (upstream-documented manual path: install.cjs).
RUN npm install -g --no-fund --no-audit --no-progress --ignore-scripts \
        "@anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}" \
 && node /usr/local/lib/node_modules/@anthropic-ai/claude-code/install.cjs \
 && claude --version | grep "${CLAUDE_CODE_VERSION}" >/dev/null \
 && echo "verified claude-code ${CLAUDE_CODE_VERSION}"

FROM node:22-slim

# Copy the globally-installed package and its bin symlink across.
COPY --from=install /usr/local/lib/node_modules/@anthropic-ai/claude-code /usr/local/lib/node_modules/@anthropic-ai/claude-code
COPY --from=install /usr/local/bin/claude /usr/local/bin/claude

# Sanity check at image-build time.
RUN claude --version

# Drop root: node:22-slim ships a non-root `node` user (uid 1000). The
# chat container is ephemeral, has no writable mounts, and only ever
# runs `claude` against MCP-exposed read-only tools — running as the
# pre-existing `node` user is the minimum-privilege baseline.
USER node
WORKDIR /home/node

ENTRYPOINT ["/usr/local/bin/claude"]
